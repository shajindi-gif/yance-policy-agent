{
  "manifest_version": 3,
  "name": "YanCe Policy Agent",
  "version": "2.0.0",
  "description": "yance.ai 园区政策分析助手 - 8维匹配引擎、材料缺口分析、ParkOps工单生成",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
