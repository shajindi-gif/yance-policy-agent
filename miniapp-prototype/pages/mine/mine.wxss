/* pages/mine/mine.wxss */
/* YanCe Policy Agent - My Profile Page Styles */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

/* ============================================
   Profile Header
   ============================================ */
.profile-header {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #0d1b2a 0%, #112240 50%, #0d1b2a 100%);
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
}

.profile-header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 50% 30%, rgba(99, 102, 241, 0.12) 0%, transparent 60%);
}

.profile-content {
  position: relative;
}

.profile-info {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0ea5e9 0%, #f97316 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.avatar-login {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  box-shadow: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.profile-text {
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.profile-role {
  font-size: 24rpx;
  color: rgba(147, 180, 248, 0.7);
  margin-top: 4rpx;
}

/* Stats */
.profile-stats {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.profile-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.profile-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #38bdf8;
}

.profile-stat-label {
  font-size: 22rpx;
  color: rgba(147, 180, 248, 0.7);
  margin-top: 4rpx;
}

/* ============================================
   Quick Settings
   ============================================ */
.quick-settings {
  margin: 20rpx 32rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  flex-direction: column;
}

.setting-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.setting-desc {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 2rpx;
}

.setting-switch {
  transform: scale(0.8);
}

/* ============================================
   Menu Groups
   ============================================ */
.menu-section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.menu-group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
  display: block;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f8fafc;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8fafc;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-label {
  font-size: 28rpx;
  color: #1a1a2e;
}

.menu-item-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.menu-badge {
  background: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.menu-extra {
  font-size: 24rpx;
  color: #94a3b8;
}

.menu-arrow {
  font-size: 32rpx;
  color: #c0c8d8;
}

/* ============================================
   Logout
   ============================================ */
.logout-section {
  padding: 40rpx 32rpx;
}

.btn-logout {
  background: #ffffff;
  color: #ef4444;
  border: 2rpx solid #fee2e2;
  font-size: 28rpx;
  font-weight: 500;
  padding: 24rpx;
  border-radius: 12rpx;
}

.btn-logout::after {
  border: none;
}

.btn-logout:active {
  background: #fef2f2;
}

/* ============================================
   Footer
   ============================================ */
.mine-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #c0c8d8;
  line-height: 1.8;
}
