/* pages/report/report.wxss */
/* YanCe Policy Agent - Service Report Styles */
/* Brand: yance.ai | Navy/Teal/Coral */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 60rpx;
}

/* ============================================
   Report Header
   ============================================ */
.report-header {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #0d1b2a 0%, #112240 50%, #0d1b2a 100%);
  border-radius: 0 0 32rpx 32rpx;
  overflow: hidden;
}

.report-header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: radial-gradient(ellipse at 30% 20%, rgba(14, 165, 233, 0.15) 0%, transparent 50%),
              radial-gradient(ellipse at 70% 80%, rgba(249, 115, 22, 0.08) 0%, transparent 50%);
}

.report-header-content {
  position: relative;
}

.report-header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.report-header-actions {
  display: flex;
  gap: 12rpx;
}

.report-logo {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.report-logo-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.export-btn {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #7dd3fc;
  line-height: 1.4;
}

.export-btn::after {
  border: none;
}

.share-btn {
  background: rgba(249, 115, 22, 0.2);
  border: 1rpx solid rgba(249, 115, 22, 0.35);
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #fb923c;
  line-height: 1.4;
}

.share-btn::after {
  border: none;
}

.report-brand {
  font-size: 22rpx;
  font-weight: 600;
  color: #f97316;
  display: block;
  margin-bottom: 8rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.report-company {
  font-size: 28rpx;
  color: #7dd3fc;
  display: block;
  margin-bottom: 8rpx;
}

.report-meta {
  font-size: 22rpx;
  color: rgba(125, 211, 252, 0.6);
  display: block;
}

/* ============================================
   Loading
   ============================================ */
.report-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.matching-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #0ea5e9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}

/* ============================================
   Table of Contents
   ============================================ */
.toc-card {
  margin: 20rpx 32rpx;
}

.toc-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 16rpx;
}

.toc-list {
  display: flex;
  flex-direction: column;
}

.toc-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.toc-number {
  font-size: 24rpx;
  font-weight: 600;
  color: #0ea5e9;
  width: 48rpx;
  flex-shrink: 0;
}

.toc-text {
  font-size: 24rpx;
  color: #374151;
}

/* ============================================
   Report Sections
   ============================================ */
.report-section {
  margin: 16rpx 32rpx;
  padding: 28rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.section-number {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.section-icon {
  font-size: 28rpx;
}

.section-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  flex: 1;
}

/* ============================================
   Content Block Types
   ============================================ */

/* Text */
.block-text {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.7;
}

/* Subtitle */
.block-subtitle {
  font-size: 26rpx;
  font-weight: 600;
  color: #0ea5e9;
  margin-bottom: 12rpx;
  margin-top: 8rpx;
}

/* List */
.block-list {
  margin-bottom: 16rpx;
}

.block-list-item {
  display: flex;
  align-items: flex-start;
  padding: 4rpx 0;
}

.list-bullet {
  color: #0ea5e9;
  font-size: 28rpx;
  font-weight: 700;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.6;
}

.list-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  flex: 1;
}

/* Warning List */
.block-warning-list {
  margin-bottom: 16rpx;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
  background: #fffbeb;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
}

.warning-icon {
  margin-right: 8rpx;
  flex-shrink: 0;
  font-size: 24rpx;
}

.warning-text {
  font-size: 26rpx;
  color: #92400e;
  line-height: 1.5;
  flex: 1;
}

/* Checklist */
.block-checklist {
  margin-bottom: 16rpx;
}

.checklist-item {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}

.checklist-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  background: #f1f5f9;
  color: #94a3b8;
}

.checklist-icon.checked {
  background: #ecfdf5;
  color: #10b981;
}

.checklist-text {
  font-size: 26rpx;
  color: #374151;
}

/* Table */
.block-table {
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #e2e8f0;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #e2e8f0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-header {
  background: #f8fafc;
}

.table-header .table-cell {
  font-weight: 600;
  color: #1a1a2e;
}

.table-cell {
  flex: 1;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #374151;
  border-right: 1rpx solid #e2e8f0;
}

.table-cell:last-child {
  border-right: none;
}

.table-cell-label {
  min-width: 0;
}

/* ============================================
   Share Section
   ============================================ */
.share-section {
  padding: 20rpx 32rpx 0;
}

/* ============================================
   Export Section
   ============================================ */
.export-section {
  padding: 0 32rpx;
  margin-top: 20rpx;
}

.export-options {
  display: flex;
  gap: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.export-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
}

.export-option:active {
  background: #e0f2fe;
}

.export-option-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.export-option-label {
  font-size: 22rpx;
  color: #374151;
  text-align: center;
}

/* ============================================
   Disclaimer
   ============================================ */
.disclaimer {
  padding: 32rpx;
  text-align: center;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

.disclaimer-brand {
  font-size: 22rpx;
  color: #f97316;
  font-weight: 500;
  display: block;
}
