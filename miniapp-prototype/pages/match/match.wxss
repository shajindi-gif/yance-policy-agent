/* pages/match/match.wxss */
/* YanCe Policy Agent - Policy Matching Results Styles */
/* Brand: yance.ai | Navy/Teal/Coral */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 160rpx;
}

/* ============================================
   Company Info Bar
   ============================================ */
.company-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f1f5f9;
}

.company-bar-info {
  display: flex;
  flex-direction: column;
}

.company-bar-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.company-bar-meta {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
}

/* ============================================
   Improved Matching Animation
   ============================================ */
.matching-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.matching-animation {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.pulse-ring {
  position: absolute;
  border-radius: 50%;
  border: 3rpx solid #0ea5e9;
  animation: pulse-expand 2s ease-out infinite;
}

.pulse-ring-1 {
  width: 80rpx;
  height: 80rpx;
  animation-delay: 0s;
}

.pulse-ring-2 {
  width: 80rpx;
  height: 80rpx;
  animation-delay: 0.5s;
}

.pulse-ring-3 {
  width: 80rpx;
  height: 80rpx;
  animation-delay: 1s;
}

@keyframes pulse-expand {
  0% {
    width: 80rpx;
    height: 80rpx;
    opacity: 0.8;
  }
  100% {
    width: 200rpx;
    height: 200rpx;
    opacity: 0;
  }
}

.matching-center-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  z-index: 1;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.4);
  animation: icon-bounce 1s ease-in-out infinite alternate;
}

@keyframes icon-bounce {
  0% { transform: scale(1); }
  100% { transform: scale(1.1); }
}

.matching-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

.matching-steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
  width: 100%;
  max-width: 400rpx;
}

.matching-step {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
  transition: all 0.3s ease;
}

.matching-step.step-active {
  color: #0ea5e9;
}

.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e2e8f0;
  transition: all 0.3s ease;
}

.step-active .step-dot {
  background: #0ea5e9;
  box-shadow: 0 0 8rpx rgba(14, 165, 233, 0.5);
}

.matching-sub {
  font-size: 22rpx;
  color: #f97316;
  font-weight: 500;
}

/* ============================================
   Match Summary Card
   ============================================ */
.match-summary {
  margin: 20rpx 32rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.score-circle {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.1;
}

.score-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
}

.summary-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.summary-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-stat-bar {
  width: 100%;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.summary-stat-high {
  background: linear-gradient(135deg, #10b981, #059669);
}

.summary-stat-medium {
  background: linear-gradient(135deg, #f97316, #ea580c);
}

.summary-stat-low {
  background: linear-gradient(135deg, #94a3b8, #64748b);
}

.summary-stat-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.summary-stat-label {
  font-size: 22rpx;
  color: #64748b;
}

.summary-total {
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
}

/* ============================================
   Sections
   ============================================ */
.section {
  padding: 0 32rpx;
  margin-top: 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* ============================================
   Policy Cards
   ============================================ */
.policy-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.policy-header {
  width: 100%;
}

.policy-title-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.match-score {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.match-score-high {
  background: linear-gradient(135deg, #10b981, #059669);
}

.match-score-medium {
  background: linear-gradient(135deg, #f97316, #ea580c);
}

.match-score-low {
  background: linear-gradient(135deg, #94a3b8, #64748b);
}

.policy-title-info {
  flex: 1;
  min-width: 0;
}

.policy-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.policy-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
}

.policy-window {
  font-size: 22rpx;
  color: #64748b;
}

/* ============================================
   Expanded Policy Detail
   ============================================ */
.policy-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f5f9;
}

.detail-section {
  margin-bottom: 20rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #0ea5e9;
  display: block;
  margin-bottom: 8rpx;
}

.detail-content {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

/* Conditions */
.condition-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.condition-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.condition-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  flex-shrink: 0;
}

.condition-icon.met {
  background: #ecfdf5;
  color: #10b981;
}

.condition-icon.unmet {
  background: #fef2f2;
  color: #ef4444;
}

.condition-text {
  font-size: 26rpx;
  color: #374151;
}

/* Missing materials */
.missing-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.missing-item {
  font-size: 24rpx;
  color: #ef4444;
  line-height: 1.6;
}

/* ============================================
   Material Gaps
   ============================================ */
.gaps-card {
  padding: 24rpx;
}

.gap-item {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.gap-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.gap-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.gap-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.gap-suggestion {
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
  padding-left: 4rpx;
}

/* ============================================
   Report CTA
   ============================================ */
.report-cta {
  padding: 32rpx;
}

/* ============================================
   Tag Variants
   ============================================ */
.tag-danger {
  background: #fef2f2;
  color: #ef4444;
}
