/* pages/index/index.wxss */
/* YanCe Policy Agent - Home Page Styles */
/* Brand: yance.ai | Navy/Teal/Coral */

.page {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 120rpx;
}

/* ============================================
   Hero Header (gradient: navy to teal)
   ============================================ */
.hero-header {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #0d1b2a 0%, #112240 40%, #0e3a5c 100%);
  border-radius: 0 0 40rpx 40rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 30% 20%, rgba(14, 165, 233, 0.18) 0%, transparent 55%),
              radial-gradient(ellipse at 80% 80%, rgba(249, 115, 22, 0.08) 0%, transparent 50%);
}

.hero-content {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

/* Logo Image (circular blue logo from assets) */
.hero-logo-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.35);
  background: #ffffff;
}

.hero-info {
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: #f97316;
  margin-top: 6rpx;
  font-weight: 500;
}

/* Park Selector */
.park-selector {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.park-selector:active {
  background: rgba(255, 255, 255, 0.12);
}

.park-info {
  display: flex;
  flex-direction: column;
}

.park-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.park-region {
  font-size: 22rpx;
  color: rgba(125, 211, 252, 0.7);
  margin-top: 4rpx;
}

.park-arrow {
  font-size: 20rpx;
  color: rgba(125, 211, 252, 0.6);
}

/* Stats Bar */
.stats-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #38bdf8;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(125, 211, 252, 0.7);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* ============================================
   Sections
   ============================================ */
.section {
  padding: 28rpx 32rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.section-more {
  font-size: 24rpx;
  color: #0ea5e9;
}

/* ============================================
   Quick Actions — 2x2 Grid
   ============================================ */
.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-grid-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(13, 27, 42, 0.06);
  transition: transform 0.15s, box-shadow 0.15s;
}

.action-grid-card:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 12rpx rgba(13, 27, 42, 0.08);
}

.action-grid-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-grid-icon {
  font-size: 40rpx;
}

.action-grid-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 6rpx;
  line-height: 1.3;
}

.action-grid-desc {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
}

/* ============================================
   Service List
   ============================================ */
.service-list {
  margin-top: 8rpx;
}

.service-item {
  padding: 24rpx;
}

.service-item:active {
  background: #f8fafc;
}

.service-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.service-company {
  display: flex;
  align-items: center;
}

.service-company-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.service-summary {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-bottom: 8rpx;
}

.service-date {
  font-size: 22rpx;
  color: #94a3b8;
}

/* ============================================
   Powered By Footer
   ============================================ */
.powered-by {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 20rpx;
  gap: 8rpx;
}

.powered-text {
  font-size: 22rpx;
  color: #c0c8d8;
}

.powered-brand {
  font-size: 22rpx;
  color: #f97316;
  font-weight: 600;
}

/* ============================================
   Park Picker Modal
   ============================================ */
.park-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.park-picker-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 70vh;
}

.park-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.park-picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.park-picker-close {
  font-size: 32rpx;
  color: #94a3b8;
  padding: 8rpx;
}

.park-picker-list {
  max-height: 60vh;
  padding: 0 32rpx;
}

.park-picker-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.park-picker-item.active {
  background: #e0f2fe;
  margin: 0 -32rpx;
  padding: 24rpx 32rpx;
  border-radius: 12rpx;
}

.park-picker-item-content {
  display: flex;
  flex-direction: column;
}

.park-picker-item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.park-picker-item-region {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}
