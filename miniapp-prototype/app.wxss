/* ============================================
   YanCe Policy Agent Mini Program - Global Styles
   Navy (#0d1b2a) / Teal (#0ea5e9) / Coral (#f97316)
   Brand: yance.ai  |  Version 1.0.0
   ============================================ */

/* ============================================
   CSS Variables via class conventions
   ============================================ */
/* Primary: Navy #0d1b2a
   Accent:  Teal #0ea5e9
   Action:  Coral #f97316
   Surface: #f5f6fa
   Card:    #ffffff
   Text:    #1a1a2e / #374151 / #64748b / #94a3b8
   Border:  #e2e8f0 / #f1f5f9
   Success: #10b981
   Warning: #f59e0b
   Danger:  #ef4444 */

/* Reset & Base */
page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue',
    'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ============================================
   Color Utility Classes
   ============================================ */
.text-primary { color: #0ea5e9; }
.text-secondary { color: #64748b; }
.text-success { color: #10b981; }
.text-warning { color: #f59e0b; }
.text-danger { color: #ef4444; }
.text-white { color: #ffffff; }
.text-muted { color: #94a3b8; }
.text-coral { color: #f97316; }
.text-navy { color: #0d1b2a; }

.bg-primary { background-color: #0ea5e9; }
.bg-dark { background-color: #0d1b2a; }
.bg-white { background-color: #ffffff; }
.bg-light { background-color: #f5f6fa; }
.bg-success { background-color: #10b981; }
.bg-warning { background-color: #f59e0b; }
.bg-coral { background-color: #f97316; }

/* ============================================
   Layout Utilities
   ============================================ */
.container {
  padding: 24rpx 32rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ============================================
   Card Component (improved shadows & radius)
   ============================================ */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(13, 27, 42, 0.06);
}

.card-dark {
  background: #0d1b2a;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(13, 27, 42, 0.15);
}

.card-elevated {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(13, 27, 42, 0.10);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

/* ============================================
   Button Component
   ============================================ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 1.4;
  transition: opacity 0.2s, transform 0.15s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(14, 165, 233, 0.25);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-secondary {
  background: #e0f2fe;
  color: #0ea5e9;
  border: 2rpx solid #bae6fd;
}

.btn-secondary:active {
  background: #bae6fd;
}

.btn-coral {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.25);
}

.btn-coral:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-outline {
  background: transparent;
  color: #0ea5e9;
  border: 2rpx solid #0ea5e9;
}

.btn-outline:active {
  background: #e0f2fe;
}

.btn-block {
  width: 100%;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 10rpx;
}

.btn-lg {
  padding: 28rpx 48rpx;
  font-size: 32rpx;
}

/* ============================================
   Form Elements
   ============================================ */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 84rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-input-focus {
  border-color: #0ea5e9;
  box-shadow: 0 0 0 4rpx rgba(14, 165, 233, 0.1);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 84rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ============================================
   Tag Component
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: #e0f2fe;
  color: #0ea5e9;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-coral {
  background: #fff7ed;
  color: #f97316;
}

.tag-success {
  background: #ecfdf5;
  color: #10b981;
}

.tag-warning {
  background: #fffbeb;
  color: #f59e0b;
}

.tag-danger {
  background: #fef2f2;
  color: #ef4444;
}

/* ============================================
   List Component
   ============================================ */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
  margin-left: 20rpx;
}

.list-item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.list-item-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
}

/* ============================================
   Badge & Status
   ============================================ */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 18rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot-active {
  background: #10b981;
}

.status-dot-pending {
  background: #f59e0b;
}

.status-dot-inactive {
  background: #94a3b8;
}

/* ============================================
   Divider
   ============================================ */
.divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 20rpx 0;
}

/* ============================================
   Section Header
   ============================================ */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.section-more {
  font-size: 24rpx;
  color: #0ea5e9;
}

/* ============================================
   Empty State
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
}

/* ============================================
   Loading
   ============================================ */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #94a3b8;
  margin-left: 16rpx;
}

/* ============================================
   Skeleton Screen (improved pulse effect)
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 37%, #f1f5f9 63%);
  background-size: 400% 100%;
  animation: skeleton-shimmer 1.4s ease infinite;
  border-radius: 8rpx;
}

.skeleton-line {
  height: 28rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.skeleton-line-short {
  width: 60%;
}

.skeleton-line-medium {
  width: 80%;
}

.skeleton-line-full {
  width: 100%;
}

.skeleton-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.skeleton-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(13, 27, 42, 0.06);
}

@keyframes skeleton-shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

/* ============================================
   Animation Keyframes
   ============================================ */

/* Fade in */
@keyframes fade-in {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-fade-in {
  animation: fade-in 0.4s ease forwards;
}

/* Slide up */
@keyframes slide-up {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-slide-up {
  animation: slide-up 0.5s ease forwards;
}

/* Pulse for matching progress */
@keyframes pulse-ring {
  0% { transform: scale(0.8); opacity: 0.8; }
  50% { transform: scale(1.1); opacity: 0.4; }
  100% { transform: scale(1.4); opacity: 0; }
}

/* Checkmark pop */
@keyframes checkmark-pop {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

.animate-checkmark {
  animation: checkmark-pop 0.4s ease forwards;
}

/* Spin */
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Bounce */
@keyframes icon-bounce {
  0% { transform: scale(1); }
  100% { transform: scale(1.1); }
}

/* ============================================
   Share Button Styles
   ============================================ */
.share-btn-coral {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 14rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(249, 115, 22, 0.25);
}

.share-btn-coral::after {
  border: none;
}

.share-btn-coral:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.share-btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 24rpx 0;
  background: transparent;
  color: #f97316;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 14rpx;
  border: 2rpx solid #f97316;
}

.share-btn-outline::after {
  border: none;
}

.share-btn-outline:active {
  background: #fff7ed;
}

/* ============================================
   Safe Area Bottom
   ============================================ */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============================================
   Branding Footer (reusable)
   ============================================ */
.brand-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 48rpx;
}

.brand-footer-text {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.8;
}

.brand-footer-link {
  font-size: 22rpx;
  color: #f97316;
  font-weight: 500;
}

/* ============================================
   Tab Bar Customization
   ============================================ */
.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
