/* ============================================
   YanCe Policy Agent Mini Program - Global Styles
   Navy (#0d1b2a) / Teal (#0ea5e9) / Coral (#f97316)
   Brand: yance.ai
   ============================================ */

/* Reset & Base */
page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue',
    'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ============================================
   Color Variables (used via class names)
   ============================================ */

/* Primary Colors — Navy/Teal/Coral */
.text-primary { color: #0ea5e9; }
.text-secondary { color: #64748b; }
.text-success { color: #10b981; }
.text-warning { color: #f59e0b; }
.text-danger { color: #ef4444; }
.text-white { color: #ffffff; }
.text-muted { color: #94a3b8; }
.text-coral { color: #f97316; }
.text-navy { color: #0d1b2a; }

.bg-primary { background-color: #0ea5e9; }
.bg-dark { background-color: #0d1b2a; }
.bg-white { background-color: #ffffff; }
.bg-light { background-color: #f5f6fa; }
.bg-success { background-color: #10b981; }
.bg-warning { background-color: #f59e0b; }
.bg-coral { background-color: #f97316; }

/* ============================================
   Layout Utilities
   ============================================ */
.container {
  padding: 24rpx 32rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ============================================
   Card Component
   ============================================ */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-dark {
  background: #0d1b2a;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
}

/* ============================================
   Button Component
   ============================================ */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  line-height: 1.4;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  background: #e0f2fe;
  color: #0ea5e9;
  border: 2rpx solid #bae6fd;
}

.btn-secondary:active {
  background: #bae6fd;
}

.btn-coral {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: #ffffff;
}

.btn-coral:active {
  opacity: 0.85;
}

.btn-outline {
  background: transparent;
  color: #0ea5e9;
  border: 2rpx solid #0ea5e9;
}

.btn-block {
  width: 100%;
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.btn-lg {
  padding: 28rpx 48rpx;
  font-size: 32rpx;
}

/* ============================================
   Form Elements
   ============================================ */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #0ea5e9;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ============================================
   Tag Component
   ============================================ */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  background: #e0f2fe;
  color: #0ea5e9;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-coral {
  background: #fff7ed;
  color: #f97316;
}

.tag-success {
  background: #ecfdf5;
  color: #10b981;
}

.tag-warning {
  background: #fffbeb;
  color: #f59e0b;
}

.tag-danger {
  background: #fef2f2;
  color: #ef4444;
}

/* ============================================
   List Component
   ============================================ */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
  margin-left: 20rpx;
}

.list-item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.list-item-desc {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
}

/* ============================================
   Badge & Status
   ============================================ */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 18rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot-active {
  background: #10b981;
}

.status-dot-pending {
  background: #f59e0b;
}

.status-dot-inactive {
  background: #94a3b8;
}

/* ============================================
   Divider
   ============================================ */
.divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 20rpx 0;
}

/* ============================================
   Section Header
   ============================================ */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.section-more {
  font-size: 24rpx;
  color: #0ea5e9;
}

/* ============================================
   Empty State
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: #94a3b8;
  text-align: center;
}

/* ============================================
   Loading
   ============================================ */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #94a3b8;
  margin-left: 16rpx;
}

/* ============================================
   Skeleton Screen
   ============================================ */
.skeleton {
  background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s infinite;
  border-radius: 8rpx;
}

.skeleton-line {
  height: 28rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

.skeleton-line-short {
  width: 60%;
}

.skeleton-line-medium {
  width: 80%;
}

.skeleton-line-full {
  width: 100%;
}

.skeleton-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.skeleton-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ============================================
   Safe Area Bottom
   ============================================ */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============================================
   Tab Bar Customization
   ============================================ */
.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
